generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  role      String   @default("Agent")
  color     String   @default("indigo")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  tickets        Ticket[]
  replies        TicketReply[]
  projectMembers ProjectMember[]

  @@map("users")
}

model Customer {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  company      String?
  phone        String?
  notes        String?
  password     String?
  monthlyPrice Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tickets   Ticket[]
  projects  Project[]

  @@map("customers")
}

model Ticket {
  id         Int           @id @default(autoincrement())
  subject    String
  body       String
  fromEmail  String
  fromName   String?
  category   String        @default("Genel")
  status     String        @default("Yeni")
  assigneeId Int?
  assignee   User?         @relation(fields: [assigneeId], references: [id])
  customerId Int?
  customer   Customer?     @relation(fields: [customerId], references: [id])
  priority          String        @default("Normal")
  source            String?       @default("web")
  telegramChatId    String?
  telegramMessageId Int?          @unique
  emailMessageId    String?       @unique
  receivedAt        DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  replies           TicketReply[]

  @@map("tickets")
}

model TicketReply {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])
  body        String
  isInternal  Boolean  @default(false)
  attachments String?  @default("[]")
  createdAt   DateTime @default(now())

  @@map("ticket_replies")
}

model Project {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  status      String          @default("Devam Ediyor")
  customerId  Int?
  customer    Customer?       @relation(fields: [customerId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  members     ProjectMember[]
  steps       ProjectStep[]
  logs        ProjectLog[]
  messages    ProjectMessage[]

  @@map("projects")
}

model ProjectMember {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectStep {
  id        Int           @id @default(autoincrement())
  projectId Int
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  order     Int           @default(0)
  status    String        @default("Beklemede")
  tasks     ProjectTask[]

  @@map("project_steps")
}

model ProjectTask {
  id           Int         @id @default(autoincrement())
  stepId       Int
  step         ProjectStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  assigneeId   Int?
  assigneeType String?
  status       String      @default("Beklemede")
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  @@map("project_tasks")
}

model ProjectLog {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int?
  userName  String?
  action    String
  createdAt DateTime @default(now())

  @@map("project_logs")
}

model ProjectMessage {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      Int?
  userName    String?
  userType    String   @default("user")
  body        String
  attachments String?  @default("[]")
  createdAt   DateTime @default(now())

  @@map("project_messages")
}
